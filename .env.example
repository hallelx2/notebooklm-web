# ----------------------------------------------------------------------------
# Required for every deployment
# ----------------------------------------------------------------------------

# Postgres with pgvector (Neon, Supabase, etc.)
DATABASE_URL=

# Better Auth -- generate with `openssl rand -hex 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# AES-256-GCM key used to encrypt user-supplied API keys at rest.
# 32 bytes -- generate with `openssl rand -hex 32` (64 hex chars).
# DO NOT change this once users have saved credentials -- their keys become
# unrecoverable. Keep it in your secret manager.
ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# Optional fallbacks
#
# Users normally configure their own AI provider keys from the in-app settings
# dashboard (/settings/providers), which encrypts and stores them in the DB.
# The variables below are only used as a safety-net default for the
# maintainer's own deployment during the migration period -- they're not
# required for new forks.
# ----------------------------------------------------------------------------

GOOGLE_GENERATIVE_AI_API_KEY=
# Legacy alias still read for backwards-compat:
GOOGLE_GEMINI_API_KEY=

# ----------------------------------------------------------------------------
# Authentication providers (optional)
# ----------------------------------------------------------------------------

# Google OAuth -- leave empty to disable Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# Web search (optional -- powers /api/deep-research)
# ----------------------------------------------------------------------------

EXA_API_KEY=
TAVILY_API_KEY=
SERPAPI_KEY=

# ----------------------------------------------------------------------------
# File storage -- pick one
# ----------------------------------------------------------------------------

# STORAGE_PROVIDER=supabase | r2
STORAGE_PROVIDER=supabase

# Supabase storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=sources

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ----------------------------------------------------------------------------
# Audio overview (optional -- requires Deepgram for TTS)
# ----------------------------------------------------------------------------

DEEPGRAM_API_KEY=
